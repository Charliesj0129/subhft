# HFT Platform - Required Environment Variables
# Copy to .env and fill in values before starting services.

# ClickHouse
CLICKHOUSE_PASSWORD=

# Redis
REDIS_PASSWORD=

# Grafana
GRAFANA_ADMIN_PASSWORD=

# Shioaji Broker (required for live/sim mode)
SHIOAJI_API_KEY=
SHIOAJI_SECRET_KEY=

# Runtime
HFT_MODE=sim

# Order execution mode (sim = simulated, live = REAL MONEY)
# WARNING: HFT_ORDER_MODE=live will place REAL orders
HFT_ORDER_MODE=sim

# CA activation (required for live futures/options trading)
# CA_CERT_DIR is the HOST directory containing your cert file
# CA_CERT_PATH is the CONTAINER path to the cert file
# CA_CERT_PATH=/app/certs/Sinopac.pfx
# CA_PASSWORD=
# SHIOAJI_ACTIVATE_CA=1
# IMPORTANT: Set HFT_ORDER_NO_CA=0 to enable CA (default is 1 = disabled)
# HFT_ORDER_NO_CA=0

# StormGuard feed gap (seconds before HALT)
# Day session: 30s (default), Night session: recommend 60s (lower liquidity)
# HFT_STORMGUARD_FEED_GAP_HALT_S=30

# Reconnect windows (local exchange time, Asia/Taipei)
HFT_RECONNECT_DAYS=mon,tue,wed,thu,fri
HFT_RECONNECT_HOURS=08:30-13:35
HFT_RECONNECT_HOURS_2=14:55-05:05
HFT_RECONNECT_TZ=Asia/Taipei

# Redis live publish (enables real-time monitor via Redis)
HFT_MONITOR_LIVE_ENABLED=1

# ─── Telegram Notifications (Phase 1) ───
# 1. 打開 Telegram，搜尋 @BotFather
# 2. 發送 /newbot → 取得 bot token（格式: 123456789:ABCdef...）
# 3. 打開 https://api.telegram.org/bot<TOKEN>/getUpdates
# 4. 發一條訊息給你的 bot，重新整理上面的頁面
# 5. 找到 "chat":{"id":123456789} → 這就是你的 chat_id
HFT_TELEGRAM_BOT_TOKEN=
HFT_TELEGRAM_CHAT_ID=
HFT_TELEGRAM_ENABLED=0

# ─── Shadow Trading (Phase 2) ───
# 啟用後 OrderAdapter 攔截所有委託，只記錄不下單
# HFT_ORDER_SHADOW_MODE=1

# Remote Monitor (make monitor-remote)
# MONITOR_REMOTE_USER=
# MONITOR_REMOTE_HOST=

# HFT Platform - Required Environment Variables
# Copy to .env and fill in values before starting services.
#
# ⚠️  WARNING: Never overwrite a production .env with this template.
#     Use `diff .env.example .env` to check for new variables instead.
#     Backup first: cp .env .env.backup.$(date +%Y%m%d)

# ─── Infrastructure ───

# ClickHouse (used by docker-compose for CH container + all services)
# IMPORTANT: All services (engine, wal-loader, monitor) must share the same password.
# HFT_CLICKHOUSE_PORT=8123 is HTTP (for clickhouse_connect). Port 9000 is native (clickhouse_driver).
# Naming convention:
#   CLICKHOUSE_PASSWORD  → Docker container (server-side auth)
#   HFT_CLICKHOUSE_*     → Platform code (client-side connection)
#   HFT_CLICKHOUSE_USER  → Canonical username (NOT HFT_CLICKHOUSE_USERNAME or CLICKHOUSE_USERNAME)
CLICKHOUSE_PASSWORD=
HFT_CLICKHOUSE_ENABLED=1
HFT_CLICKHOUSE_HOST=clickhouse
HFT_CLICKHOUSE_PORT=8123
# HFT_CLICKHOUSE_USER=default

# Redis (used by all services: session lease, monitor, emergency halt)
# Naming convention:
#   REDIS_PASSWORD        → Docker container (server-side auth)
#   HFT_REDIS_PASSWORD    → Platform code fallback
#   HFT_MONITOR_REDIS_PASSWORD → Defaults to REDIS_PASSWORD if unset
REDIS_PASSWORD=

# Grafana
GRAFANA_ADMIN_PASSWORD=

# ─── Broker (Shioaji) ───

SHIOAJI_API_KEY=
SHIOAJI_SECRET_KEY=
# SHIOAJI_PERSON_ID=

# CA activation (required for live futures/options trading)
# CA_CERT_PATH=./certs/Sinopac.pfx
# CA_PASSWORD=
# SHIOAJI_ACTIVATE_CA=1
# HFT_ORDER_NO_CA=0

# ─── Runtime Mode ───

HFT_MODE=sim

# Order execution mode (sim = simulated, live = REAL MONEY)
# WARNING: HFT_ORDER_MODE=live will place REAL orders
HFT_ORDER_MODE=sim

# ─── Feature Engine ───
# HFT_FEATURE_ENGINE_ENABLED=1         # 0 = disable FeatureEngine (default: 1, v3 with 27 features)
# HFT_FEATURE_ENGINE_BACKEND=python    # python | rust
# HFT_FUSED_NORMALIZER=0               # 1 = enable fused Rust normalizer+LOB pipeline

# ─── Gateway ───
# HFT_GATEWAY_ENABLED=0                # 1 = enable CE-M2 order/risk gateway

# ─── Symbols ───
# HFT_SYMBOLS=                         # Comma-separated symbol override (e.g., TXFD6,MXFD6)
# HFT_QUOTE_VERSION=auto               # Shioaji quote protocol version

# ─── Shadow Trading (Phase 2) ───
# Enables shadow order interception: strategies run, orders logged, never sent to broker
# Requires HFT_ORDER_MODE=sim (dual-lock: shadow + live = startup refused)
# HFT_ORDER_SHADOW_MODE=1

# ─── StormGuard ───
# Feed gap threshold (seconds without tick before HALT)
# Day session: 30s (default), Night session: recommend 60s (lower liquidity)
# HFT_STORMGUARD_FEED_GAP_HALT_S=30

# ─── Reconnect ───
HFT_RECONNECT_DAYS=mon,tue,wed,thu,fri
HFT_RECONNECT_HOURS=08:30-13:35
HFT_RECONNECT_HOURS_2=14:55-05:05
HFT_RECONNECT_TZ=Asia/Taipei

# ─── Monitor ───
# Enable Redis live publisher (engine → Redis → remote monitor TUI)
HFT_MONITOR_LIVE_ENABLED=1
# Data source for monitor TUI: auto / ch / shm / redis
# HFT_MONITOR_DATA_SOURCE=auto
# Override Redis connection for monitor (defaults to REDIS_PASSWORD)
# HFT_MONITOR_REDIS_HOST=redis
# HFT_MONITOR_REDIS_PORT=6379
# HFT_MONITOR_REDIS_PASSWORD=

# ─── WAL / Recorder ───
# Archive retention (days). Files older than this are auto-deleted.
# HFT_ARCHIVE_RETENTION_DAYS=3

# ─── Telegram Notifications (Phase 1) ───
# 1. Telegram 搜尋 @BotFather → /newbot → 取得 token
# 2. 發訊息給 bot → 打開 https://api.telegram.org/bot<TOKEN>/getUpdates
# 3. 找到 "chat":{"id":123456789} → 填入 CHAT_ID
HFT_TELEGRAM_BOT_TOKEN=
HFT_TELEGRAM_CHAT_ID=
HFT_TELEGRAM_ENABLED=0

# ─── Remote Monitor (make monitor-remote) ───
# IMPORTANT: MONITOR_CH_PASSWORD and MONITOR_REDIS_PASSWORD must match
# CLICKHOUSE_PASSWORD and REDIS_PASSWORD on the remote host.
# MONITOR_REMOTE_USER=
# MONITOR_REMOTE_HOST=
# MONITOR_CH_PASSWORD=          # Must match remote CLICKHOUSE_PASSWORD
# MONITOR_REDIS_PASSWORD=       # Must match remote REDIS_PASSWORD

# ─── ClickHouse Backup ──────────────────────────────────────
# HFT_BACKUP_ENABLED=1        # Enable automated daily backup (default: 0)
# HFT_BACKUP_RETAIN_DAYS=30   # Number of daily backups to retain (default: 30)
# CH_BACKUP_PATH=./backups/clickhouse  # Host path for backup volume (default: ./backups/clickhouse)

# ─── Position Recovery ──────────────────────────────────────
# HFT_STARTUP_RECON_ENABLED=1             # Enable startup position recovery (default: 1)
# HFT_STARTUP_RECON_QTY_THRESHOLD=10      # Stock discrepancy threshold (default: 10)
# HFT_STARTUP_RECON_FUTURES_QTY_THRESHOLD=2  # Futures discrepancy threshold (default: 2)
# HFT_CHECKPOINT_ENABLED=1                # Enable periodic position checkpoint (default: 1)

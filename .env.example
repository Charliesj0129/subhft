# HFT Platform - Required Environment Variables
# Copy to .env and fill in values before starting services.

# ClickHouse
CLICKHOUSE_PASSWORD=

# Redis
REDIS_PASSWORD=

# Grafana
GRAFANA_ADMIN_PASSWORD=

# Shioaji Broker (required for live/sim mode)
SHIOAJI_API_KEY=
SHIOAJI_SECRET_KEY=

# Runtime
HFT_MODE=sim

# Reconnect windows (local exchange time, Asia/Taipei)
HFT_RECONNECT_DAYS=mon,tue,wed,thu,fri
HFT_RECONNECT_HOURS=08:30-13:35
HFT_RECONNECT_HOURS_2=14:55-05:05
HFT_RECONNECT_TZ=Asia/Taipei

# Redis live publish (enables real-time monitor via Redis)
HFT_MONITOR_LIVE_ENABLED=1

# Remote Monitor (make monitor-remote)
# MONITOR_REMOTE_USER=
# MONITOR_REMOTE_HOST=

<clickhouse>
    <!-- CH/MV pressure tuning baseline. -->
    <!-- Container limit: 6G; keep ~800MB headroom for allocator/OS noise. -->
    <max_server_memory_usage>5200000000</max_server_memory_usage>

    <profiles>
        <default>
            <!-- Per-query memory limit: 2GB (prevents single GROUP BY from OOM-ing the server) -->
            <max_memory_usage>2000000000</max_memory_usage>
            <!-- Overflow to disk instead of failing when query exceeds memory -->
            <max_bytes_before_external_group_by>1000000000</max_bytes_before_external_group_by>
            <max_bytes_before_external_sort>1000000000</max_bytes_before_external_sort>
        </default>
    </profiles>
</clickhouse>

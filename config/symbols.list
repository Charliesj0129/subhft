# symbols.list is the single source of truth for config/symbols.yaml
# Format:
#   CODE [key=value ...]
#   CODE,EXCHANGE[,TICK_SIZE[,PRICE_SCALE[,TAGS]]]
#
# Rules (expanded via contract cache from `python -m hft_platform config build`):
#   TXF@front
#   MXF@next
#   OPT@TXO@near@ATM+/-10
#
# Presets (uncomment to use):
# @include config/symbols.examples/minimal.list
# @include config/symbols.examples/tw50.list
# @include config/symbols.examples/futures_front.list
# @include config/symbols.examples/options_near_atm.list
# @include config/symbols.examples/options_near_otm.list
# @include config/symbols.examples/futures_options_demo.list
# @include config/symbols.examples/stress.list

# 50 TWSE stocks
@include symbols.examples/tw50.list

# Main hot futures: TXF (front+next+far), MXF (front+next), TMF (front+next), EXF (front)
TXF@front exchange=FUT tags=futures|front_month|txf
TXF@next exchange=FUT tags=futures|next_month|txf
TXF@far exchange=FUT tags=futures|far_month|txf
MXF@front exchange=FUT tags=futures|front_month|mxf
MXF@next exchange=FUT tags=futures|next_month|mxf
TMF@front exchange=FUT tags=futures|front_month|tmf
TMF@next exchange=FUT tags=futures|next_month|tmf
EXF@front exchange=FUT tags=futures|front_month|exf

# TXO option chain: 5 expiries (covers nearest weekly + monthly), ATM ± 26 strikes, both C+P
# Each expiry expands to (2*26+1) strikes * 2 rights = 106 codes → 5 expiries = 530 codes
OPT@TXO@near@ATM+/-26 exchange=OPT tags=options|near_month|atm
OPT@TXO@next@ATM+/-26 exchange=OPT tags=options|next_month|atm
OPT@TXO@far@ATM+/-26 exchange=OPT tags=options|far_month|atm
OPT@TXO@far_plus_1@ATM+/-26 exchange=OPT tags=options|far_plus_1|atm
OPT@TXO@far_plus_2@ATM+/-26 exchange=OPT tags=options|far_plus_2|atm

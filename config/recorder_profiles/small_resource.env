# Recorder profile: small_resource
# Target: 1-core VM, <=4 GB RAM
# Usage: source config/recorder_profiles/small_resource.env && hft run live
export HFT_BATCHER_MAX_BUFFER=500
export HFT_WAL_BATCH_MAX_ROWS=100
export HFT_WAL_DISK_MIN_MB=100
export HFT_WAL_DISK_PRESSURE_POLICY=drop
export HFT_WAL_LOADER_CONCURRENCY=1
export HFT_RECORDER_MODE=wal_first

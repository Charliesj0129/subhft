# Recorder profile: standard
# Target: 4-core, 16 GB, NVMe — production default
# Usage: source config/recorder_profiles/standard.env && hft run live
export HFT_BATCHER_MAX_BUFFER=2000
export HFT_WAL_BATCH_MAX_ROWS=500
export HFT_WAL_DISK_MIN_MB=500
export HFT_WAL_DISK_PRESSURE_POLICY=drop
export HFT_WAL_LOADER_CONCURRENCY=4
export HFT_RECORDER_MODE=direct

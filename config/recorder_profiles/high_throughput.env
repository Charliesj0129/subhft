# Recorder profile: high_throughput
# Target: 8-core, 64 GB, NVMe RAID
# Usage: source config/recorder_profiles/high_throughput.env && hft run live
export HFT_BATCHER_MAX_BUFFER=10000
export HFT_WAL_BATCH_MAX_ROWS=2000
export HFT_WAL_DISK_MIN_MB=2000
export HFT_WAL_DISK_PRESSURE_POLICY=warn
export HFT_WAL_LOADER_CONCURRENCY=8
export HFT_RECORDER_MODE=direct
